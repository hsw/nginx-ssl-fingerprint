+
+    /* capture JA4 fingerprint data (ciphers/extensions/sigalgs/SNI/ALPN) */
+    ngx_ssl_ja4_capture(ssl_conn);
+
     if (SSL_client_hello_get0_ext(ssl_conn, TLSEXT_TYPE_server_name,
                                   (const unsigned char **) &p, &len)
         == 0)
