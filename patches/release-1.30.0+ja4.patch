+#define NGX_SSL_JA3_BUFFER_SIZE 256 /* = (sizeof(uint16_t) * 128) */
+#define NGX_SSL_JA4_MAX_CIPHERS    200
+#define NGX_SSL_JA4_MAX_EXTENSIONS 200
+#define NGX_SSL_JA4_MAX_SIGALGS    128
 #define NGX_SSL_PASSWORD_BUFFER_SIZE  4096
 
 
@@ -2011,6 +2015,218 @@ ngx_ssl_set_client_hello_callback(ngx_ssl_t *ssl, ngx_ssl_client_hello_arg *cb)
 
