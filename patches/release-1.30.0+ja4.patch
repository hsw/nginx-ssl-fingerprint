+static void
+ngx_ssl_client_hello_ja3_cb(SSL *ssl)
+{
+    ngx_connection_t  *c;
+    ngx_str_t         *ja;
+
+    c = ngx_ssl_get_connection(ssl);
+
+    if (c == NULL || c->ssl == NULL) {
+        return;
+    }
+
+    ja = &c->ssl->fp_ja3_data;
+    ja->len = NGX_SSL_JA3_BUFFER_SIZE;
+
+    ja->data = ngx_pnalloc(c->pool, NGX_SSL_JA3_BUFFER_SIZE);
+    if (ja->data == NULL) {
+        ja->len = 0;
+        return;
+    }
+
+    ja->len = SSL_client_hello_get_ja3_data(ssl, ja->data,
+                                            NGX_SSL_JA3_BUFFER_SIZE);
+    if (ja->len == 0) {
+        ngx_log_error(NGX_LOG_WARN, c->log, 0, "SSL_client_hello_get_ja3_data "
+                "seems the buffer size is less that number of fileds; "
+                "for this SSL connection can't get a ja3 hash string");
+        ja->data = NULL;
+    }
+}
+
+
+static void
+ngx_ssl_ja4_capture(ngx_ssl_conn_t *ssl_conn)
+{
+    ngx_connection_t    *c;
+    const unsigned char *ciphers_raw;
+    size_t               ciphers_len;
+    size_t               i, n;
+    const unsigned char *data;
+    size_t               len;
+    uint16_t             val;
+
+    c = ngx_ssl_get_connection(ssl_conn);
+
+    if (c == NULL || c->ssl == NULL) {
+        return;
+    }
+
+    /* --- ciphers --- */
+
+    ciphers_len = SSL_client_hello_get0_ciphers(ssl_conn, &ciphers_raw);
+    /* ciphers_len is in bytes, each cipher is 2 bytes */
+    n = ciphers_len / 2;
+    if (n > NGX_SSL_JA4_MAX_CIPHERS) {
+        n = NGX_SSL_JA4_MAX_CIPHERS;
+    }
+
+    if (n > 0) {
+        c->ssl->fp_ja4_ciphers = ngx_palloc(c->pool,
+                                             n * sizeof(uint16_t));
+        if (c->ssl->fp_ja4_ciphers == NULL) {
+            return;
+        }
+
+        for (i = 0; i < n; i++) {
+            c->ssl->fp_ja4_ciphers[i] =
+                (uint16_t) ((ciphers_raw[i * 2] << 8)
+                            | ciphers_raw[i * 2 + 1]);
+        }
+
+        c->ssl->fp_ja4_ciphers_sz = n;
+    }
+
+    /* --- extensions --- */
+
+    {
+        const unsigned char *ext_raw;
+        size_t               ext_raw_len, pos, elen;
+
+        ext_raw_len = SSL_client_hello_get0_extensions(ssl_conn, &ext_raw);
+
+        if (ext_raw_len > 0) {
+            c->ssl->fp_ja4_extensions = ngx_palloc(c->pool,
+                                            NGX_SSL_JA4_MAX_EXTENSIONS
+                                            * sizeof(uint16_t));
+            if (c->ssl->fp_ja4_extensions == NULL) {
+                c->ssl->fp_ja4_ciphers = NULL;
+                c->ssl->fp_ja4_ciphers_sz = 0;
+                return;
+            }
+
+            n = 0;
+            pos = 0;
+
+            while (pos + 4 <= ext_raw_len
+                   && n < NGX_SSL_JA4_MAX_EXTENSIONS)
+            {
+                elen = (size_t) ((ext_raw[pos + 2] << 8)
+                                 | ext_raw[pos + 3]);
+                if (pos + 4 + elen > ext_raw_len) {
+                    break;
+                }
+
+                c->ssl->fp_ja4_extensions[n++] =
+                    (uint16_t) ((ext_raw[pos] << 8) | ext_raw[pos + 1]);
+                pos += 4 + elen;
+            }
+
+            c->ssl->fp_ja4_extensions_sz = n;
+        }
+    }
+
+    /* --- supported_versions (ext 0x002b) --- */
+
+    if (SSL_client_hello_get0_ext(ssl_conn, 0x002b, &data, &len) == 1
+        && len >= 3)
+    {
+        /* first byte is list length, then 2-byte version entries */
+        size_t  list_len = data[0];
+        size_t  j;
+
+        /* clamp list_len to actual buffer to prevent OOB read */
+        if (list_len > len - 1) {
+            list_len = len - 1;
+        }
+
+        c->ssl->fp_ja4_version = 0;
+
+        for (j = 1; j + 1 <= list_len; j += 2) {
+            val = (uint16_t) ((data[j] << 8) | data[j + 1]);
+
+            /* skip GREASE: both nibble check and identical-byte check */
+            if ((val & 0x0f0f) == 0x0a0a && (val & 0xff) == (val >> 8)) {
+                continue;
+            }
+
+            if (val > c->ssl->fp_ja4_version) {
+                c->ssl->fp_ja4_version = val;
+            }
+        }
+    } else {
+        /* no supported_versions ext: fall back to legacy_version */
+        c->ssl->fp_ja4_version = SSL_client_hello_get0_legacy_version(ssl_conn);
+    }
+
+    /* --- SNI (ext 0x0000) --- */
+
+    if (SSL_client_hello_get0_ext(ssl_conn, 0x0000, &data, &len) == 1
+        && len > 0)
+    {
+        c->ssl->fp_ja4_has_sni = 1;
+    }
+
+    /* --- signature algorithms (ext 0x000d) --- */
+
+    if (SSL_client_hello_get0_ext(ssl_conn, 0x000d, &data, &len) == 1
+        && len >= 4)
+    {
+        /* first 2 bytes: list length, then 2-byte sigalg entries */
+        size_t  sa_len = (size_t) ((data[0] << 8) | data[1]);
+        size_t  sa_count = sa_len / 2;
+        if (sa_count > NGX_SSL_JA4_MAX_SIGALGS) {
+            sa_count = NGX_SSL_JA4_MAX_SIGALGS;
+        }
+
+        if (sa_count > 0 && 2 + sa_len <= len) {
+            c->ssl->fp_ja4_sigalgs = ngx_palloc(c->pool,
+                                                 sa_count * sizeof(uint16_t));
+            if (c->ssl->fp_ja4_sigalgs == NULL) {
+                c->ssl->fp_ja4_ciphers = NULL;
+                c->ssl->fp_ja4_ciphers_sz = 0;
+                return;
+            }
+
+            for (i = 0; i < sa_count; i++) {
+                c->ssl->fp_ja4_sigalgs[i] =
+                    (uint16_t) ((data[2 + i * 2] << 8)
+                                | data[2 + i * 2 + 1]);
+            }
+            c->ssl->fp_ja4_sigalgs_sz = sa_count;
+        }
+    }
+
+    /* --- ALPN (ext 0x0010) --- */
+
+    if (SSL_client_hello_get0_ext(ssl_conn, 0x0010, &data, &len) == 1
+        && len >= 4)
+    {
+        size_t  list_len = (size_t) ((data[0] << 8) | data[1]);
+        size_t  alpn_len;
+
+        if (list_len >= 2 && 2 + list_len <= len) {
+            alpn_len = data[2];
+
+            if (alpn_len > 0 && 1 + alpn_len <= list_len) {
+                c->ssl->fp_first_alpn = ngx_pnalloc(c->pool, alpn_len + 1);
+
+                if (c->ssl->fp_first_alpn == NULL) {
+                    c->ssl->fp_ja4_ciphers = NULL;
+                    c->ssl->fp_ja4_ciphers_sz = 0;
+                    return;
+                }
+
+                ngx_memcpy(c->ssl->fp_first_alpn, &data[3], alpn_len);
+                c->ssl->fp_first_alpn[alpn_len] = '\0';
+            }
+        }
+    }
+}
+
+
 int
 ngx_ssl_client_hello_callback(ngx_ssl_conn_t *ssl_conn, int *ad, void *arg)
 {
@@ -2025,6 +2241,12 @@ ngx_ssl_client_hello_callback(ngx_ssl_conn_t *ssl_conn, int *ad, void *arg)
     cb = SSL_CTX_get_ex_data(c->ssl->session_ctx,
